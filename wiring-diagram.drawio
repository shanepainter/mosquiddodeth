        <!-- Notes                                  -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="note1" value="&lt;b&gt;Zone Operation:&lt;/b&gt; Only one relay active at a time. If multiple zones trigger simultaneously (schedule overlap), they queue and run sequentially — Zone 1 finishes, then Zone 2 starts, etc." style="text;html=1;align=left;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="960" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note2" value="&lt;b&gt;Power Budget:&lt;/b&gt; 60W PSU provides 5A at 12V. Each pump draws ~2A. With sequential operation only one pump runs at a time, so 5A is sufficient. Buck converter draws &lt;0.5A for ESP32." style="text;html=1;align=left;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="990" width="700" height="30" as="geometry" />
        </mxCell>
        <mxCell id="note3" value="&lt;b&gt;Fewer zones?&lt;/b&gt; Edit NUM_ZONES and ZONE_PINS[] in config.h. Unused relay channels are simply not wired." style="text;html=1;align=left;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="1020" width="700" height="30" as="geometry" />
        </mxCell>

