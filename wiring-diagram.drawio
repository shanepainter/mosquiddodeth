        <mxCell id="parts_box" value="&lt;b&gt;Parts List&lt;/b&gt;&lt;hr&gt;&lt;div style=&quot;text-align:left;font-size:10px;line-height:1.6&quot;&gt;1. 12V 60W IP67 Power Supply&lt;br&gt;2. 5V 1.8A Buck Converter (12V→5V)&lt;br&gt;3. ESP32-U (WROOM-32U) + 2.4GHz antenna&lt;br&gt;4. 5V Relay Module (opto-isolated)&lt;br&gt;5. 12V DC Pump (~2A)&lt;br&gt;6. Momentary pushbutton (optional)&lt;br&gt;7. Weatherproof enclosure&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#CCCCCC;arcSize=4;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1100" y="110" width="250" height="180" as="geometry" />
        </mxCell>

        <!-- ═══════════════════════════════════════ -->
        <!-- Flow note                              -->
        <!-- ═══════════════════════════════════════ -->
        <mxCell id="flow_note" value="&lt;b&gt;Signal Flow:&lt;/b&gt; ESP32 GPIO 26 HIGH → Relay IN triggers → Relay closes NO→COM → 12V reaches pump → pump runs for configured duration (default 90s)" style="text;html=1;align=left;fontSize=10;fontColor=#666666;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="80" y="930" width="700" height="30" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
